# Races Sync Service Dockerfile
# Lightweight - no Playwright needed
FROM node:20-slim

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install only production dependencies
RUN npm install --omit=dev ws

# Copy sync service
COPY races-sync-service.js ./

# No ports needed - only outbound connections
CMD ["node", "races-sync-service.js"]
